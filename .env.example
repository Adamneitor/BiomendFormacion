# BIOMEND Formación Continua — variables de entorno (plantilla)
# Copia a .env y completa. NUNCA subas .env al repositorio.

# development | production
APP_ENV=development

# Obligatorio en production. Genera con: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# PostgreSQL (SQLAlchemy + psycopg3). Obligatorio en production.
# DATABASE_URL=postgresql+psycopg://usuario:clave@localhost:5432/biomend_web
DATABASE_URL=

# Hosts permitidos separados por coma (production).
# Ej: biomendformacion.com,www.biomendformacion.com,TU-SERVICIO.up.railway.app
ALLOWED_HOSTS=

# Panel /admin
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Correo de la clienta — recibe cada inscripción completa (con adjuntos)
NOTIFY_EMAIL=

# SMTP (Gmail, Resend, Mailgun, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
